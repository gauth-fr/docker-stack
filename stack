#!/usr/bin/env bash

# Configuration
DOCKER_FILES=##DOCKER_FILES##
EDITOR=${EDITOR:-vim}
VERBOSE=0

# Constants
DEFAULT_DOCKERCOMPOSE_TEMPLATE_B64=""
DEFAULT_ENV_TEMPLATE_B64="IyNBREQvQ0hBTkdFL0VESVQgUkVRVUlSRUQgVkFSSUFCTEVTCgpQVUlEPTEyMzQKUEdJRD0xMjM0ClRaPUV1cm9wZS9QYXJpcwoKQ09ORklHRk9MREVSPSMjQ09ORklHX0ZPTERFUiMjCgpET01BSU5OQU1FPW15ZG9tYWluLmNvbQ=="
DOCKER_COMPOSE_BIN=""
CONTAINERS_PARAM=""

# File patterns and markers
COMPOSE_PATTERN='*compose.y*ml'
ENABLED_MARKER='.enabled'
PAUSED_MARKER='.paused'

# Exit codes
EXIT_SUCCESS=0
EXIT_GENERAL_ERROR=1
EXIT_DOCKER_PERMISSION=10
EXIT_NO_COMPOSE_TOOL=11
EXIT_INVALID_INPUT=255

# Colors
RED="\033[31m"
GREEN="\033[32m"
YELLOW="\033[33m"
BLUE="\033[34m"
ENDCOLOR="\033[0m"



function main() {
  # Validate DOCKER_FILES environment variable
  if [ -z "$DOCKER_FILES" ]; then
    error "Environment variable DOCKER_FILES is not set or exported!"
    exit $EXIT_GENERAL_ERROR
  fi

  # Validate DOCKER_FILES path exists and is a directory
  if [ ! -d "$DOCKER_FILES" ]; then
    error "DOCKER_FILES path does not exist or is not a directory: $DOCKER_FILES"
    exit $EXIT_GENERAL_ERROR
  fi

  debug "Using DOCKER_FILES: $DOCKER_FILES"

  # Parse verbose flag first
  while [[ "$1" == -* ]]; do
    case "${1}" in
      -v|--verbose)
        VERBOSE=1
        shift
        ;;
      *)
        break
        ;;
    esac
  done

  case "${1}" in
    start|up)
      ACTION=start
      shift # shift once since flags have no values
      ;;
    stop|down)
      ACTION=stop
      shift
      ;;
    restart)
      ACTION=restart
      shift
      ;;
    list)
      ACTION=list
      shift
      ;;
    update)
      ACTION=update
      shift
      ;;
    enable)
      ACTION=enable
      shift
      ;;
    disable)
      ACTION=disable
      shift
      ;;
    create|new)
      ACTION=create
      shift
      ;;
    remove|delete)
      ACTION=remove
      shift
      ;;
    status)
      ACTION=status
      shift
      ;;
    edit)
      ACTION=edit
      shift
      ;;
    pause)
      ACTION=pause
      shift
      ;;
    unpause)
      ACTION=unpause
      shift
      ;;
    init)
      ACTION=init
      shift
      ;;
    self-update)
      ACTION=self-update
      shift
      ;;
    help|-h)
      usage
      exit 0
      ;;
    *) # unknown flag/switch
      error "Invalid parameter: ${1}"
      usage
      exit $EXIT_INVALID_INPUT
      ;;
  esac

  set-docker-compose-bin
  
  docker-privileges-check ${ACTION}

  CONTAINERS_PARAM=$1
  
  # For actions that require specific container names, validate before container discovery
  case "$ACTION" in
    create|remove|edit)
      if [[ "$CONTAINERS_PARAM" == "all" || -z "$CONTAINERS_PARAM" ]]; then
        error "Action '$ACTION' requires a specific container name (cannot use 'all' or empty)."
        exit $EXIT_INVALID_INPUT
      fi
      ;;
  esac

  if [ -z "$CONTAINERS_PARAM" ] || [ "$CONTAINERS_PARAM" == "all" ]
  then
      debug "Discovering containers in: $DOCKER_FILES"
      #CONTAINERS=$(echo $DOCKERCOMPOSE_DIR/*/*.docker-compose.yml | sed -e "s|$DOCKERCOMPOSE_DIR/[^/]*/||g" -e "s|.docker-compose.yml||g")
      CONTAINERS=$(for f in $DOCKER_FILES/*/$COMPOSE_PATTERN ;do echo -n "$(basename $(dirname $f)) ";done;)
      debug "Found containers: $CONTAINERS"
  else
      CONTAINERS="$@"
      debug "Target containers: $CONTAINERS"
  fi

  debug "Executing action: $ACTION"
  ${ACTION} "$CONTAINERS"
}

function usage() {
  echo "stack [-v|--verbose] ACTION [STACKS LIST]"
  echo ""
  echo "Options:"
  echo "    -v, --verbose   : Enable verbose output (shows debug information)"
  echo ""
  echo "Actions:"
  echo "    ACTION=     start|up  : Start the specified stacks"
  echo "                stop|down : Stop the specified stacks"
  echo "                restart   : Restart the specified stacks"
  echo "                update    : Pull new images & restart if it was running"
  echo "                enable    : Mark an as being always considered by 'all' (for start)"
  echo "                disable   : Remove the 'enabled' flag"
  echo "                pause     : Stops the specified stacks and marks for restart - Usefull for backup"
  echo "                unpause   : Restart stacks marked by pause"
  echo ""
  echo "    STACKS LIST= all       : Process all stacks"
  echo "                List of containers   : stack1 stack2 stack3 ...."
  echo "                default   : all"
  echo ""
  echo "stack [-v|--verbose] ACTION [STACK]"
  echo "where:"
  echo "    ACTION=     create|new    : Get status of stack apps"
  echo "                delete|remove : List available stack"
  echo "                edit : edit the docker-compose file of the specified app"
  echo "    STACK=      Name of the stack to create/delete/edit"
  echo "                In the case of 'edit', it can also be template or .env."
  echo ""
  echo "stack ACTION"
  echo "where:"
  echo "    ACTION=     status      : Get status of stack apps (can take some time as it queries containers)"
  echo "                list        : List available stack"
  echo "                init        : Initialize template and .env file"
  echo "                self-update : Update script & completion"
  echo "                help        : Display this help"
  echo ""
  echo "Examples:"
  echo "    stack start myapp              # Start myapp"
  echo "    stack -v start myapp           # Start myapp with verbose output"
  echo "    stack --verbose update all     # Update all stacks with debug info"
}

function error(){
  echo -e "${RED}ERROR:${ENDCOLOR} $@" >&2
}

function warning(){
  echo -e "${YELLOW}WARNING:${ENDCOLOR} $@" >&2
}

function debug(){
  if [ $VERBOSE -eq 1 ]; then
    echo -e "${BLUE}[DEBUG]${ENDCOLOR} $@" >&2
  fi
}

function get_env_files(){
  local stack_dir="$1"
  local env_args=""
  
  debug "Loading env files from: $stack_dir"
  
  # First, add the main .env file if it exists (symlink or regular file)
  if [ -f "$stack_dir/.env" ]; then
    env_args="--env-file $stack_dir/.env"
    debug "  Found: .env"
  fi
  
  # Then, add all other .env* files in alphabetical order (excluding the main .env)
  for env_file in $(ls -1 "$stack_dir"/.env* 2>/dev/null | grep -v "^$stack_dir/\.env$" | sort); do
    if [ -f "$env_file" ]; then
      env_args="$env_args --env-file $env_file"
      debug "  Found: $(basename $env_file)"
    fi
  done
  
  echo "$env_args"
}

function docker_compose_exec(){
  local compose_file="$1"
  local env_args="$2"
  shift 2
  local compose_args="$@"
  
  debug "Executing: $DOCKER_COMPOSE_BIN -f $compose_file $env_args $compose_args"
  $DOCKER_COMPOSE_BIN -f $compose_file $env_args $compose_args
  local exit_code=$?
  
  if [ $exit_code -ne 0 ]; then
    debug "Docker compose command failed with exit code: $exit_code"
  fi
  
  return $exit_code
}

function status(){
  local containers="$@"
  for c in $containers
  do
    if ls $DOCKER_FILES/$c/$COMPOSE_PATTERN 1>/dev/null 2>&1
    then
      if ls $DOCKER_FILES/$c/$ENABLED_MARKER 1>/dev/null 2>&1
      then
        status=enabled
      else
        status=" "
      fi

      local env_args=$(get_env_files "$DOCKER_FILES/$c")
      #echo "$c"
      if [[ ! -z $(docker_compose_exec "$DOCKER_FILES/$c/$COMPOSE_PATTERN" "$env_args" "top") ]]
      then
        running_status="${GREEN}Running${ENDCOLOR}"
      else
        running_status="${RED}Stopped${ENDCOLOR}"
      fi

      echo -e "$c|$running_status|$status|" $DOCKER_FILES/$c/$COMPOSE_PATTERN
    else
      warning "No $c app found"
    fi
  done | column -t -s'|'

}

function list(){
  local containers="$@"
  for c in $containers
  do
    if ls $DOCKER_FILES/$c/$COMPOSE_PATTERN 1>/dev/null 2>&1
    then
      if ls $DOCKER_FILES/$c/$ENABLED_MARKER 1>/dev/null 2>&1
      then
        status=enabled
      else
        status=" "
      fi

      echo -e "$c|$status|" $DOCKER_FILES/$c/$COMPOSE_PATTERN
    else
      warning "No $c app found" 
    fi
  done | column -t -s'|' 

}

function start(){
  local containers="$@"
  for c in $containers
  do
    if ls $DOCKER_FILES/$c/$COMPOSE_PATTERN 1>/dev/null 2>&1
    then
      local env_args=$(get_env_files "$DOCKER_FILES/$c")
      if [ "$CONTAINERS_PARAM" == "all" ]
      then
        if ls $DOCKER_FILES/$c/$ENABLED_MARKER 1>/dev/null 2>&1
        then
          echo "Starting $c ..."
          docker_compose_exec "$DOCKER_FILES/$c/$COMPOSE_PATTERN" "$env_args" "up -d"
        fi
      else
        echo "Starting $c ..."
        docker_compose_exec "$DOCKER_FILES/$c/$COMPOSE_PATTERN" "$env_args" "up -d"
      fi
    else
      warning "No $c app found"
    fi
  done
}

function stop(){
  local containers="$@"
  for c in $containers
  do
    if ls $DOCKER_FILES/$c/$COMPOSE_PATTERN 1>/dev/null 2>&1
    then
      local env_args=$(get_env_files "$DOCKER_FILES/$c")
      echo "...Stopping $c ..."
      docker_compose_exec "$DOCKER_FILES/$c/$COMPOSE_PATTERN" "$env_args" "down"
    else
      warning "No $c app found"
    fi
  done
}

function restart() {
  local containers="$@"
  for c in $containers
  do
    if ls $DOCKER_FILES/$c/$COMPOSE_PATTERN 1>/dev/null 2>&1
    then
      local env_args=$(get_env_files "$DOCKER_FILES/$c")
      echo "Restarting $c ..."
      if [[ ! -z $(docker_compose_exec "$DOCKER_FILES/$c/$COMPOSE_PATTERN" "$env_args" "top") ]]
      then
        docker_compose_exec "$DOCKER_FILES/$c/$COMPOSE_PATTERN" "$env_args" "down"
        docker_compose_exec "$DOCKER_FILES/$c/$COMPOSE_PATTERN" "$env_args" "up -d"
      else
        warning "$c is not running. Start it first."
      fi
        
    else
      warning "No $c app found"
    fi
    echo
  done

}

function update(){
  local containers="$@"
  for c in $containers
  do
	if ls $DOCKER_FILES/$c/$COMPOSE_PATTERN 1>/dev/null 2>&1
	then
		local env_args=$(get_env_files "$DOCKER_FILES/$c")
		echo "Updating $c ..."
		docker_compose_exec "$DOCKER_FILES/$c/$COMPOSE_PATTERN" "$env_args" "pull"
		if [[ ! -z $(docker_compose_exec "$DOCKER_FILES/$c/$COMPOSE_PATTERN" "$env_args" "top") ]]
		then
			echo "Restarting $c ..."
			docker_compose_exec "$DOCKER_FILES/$c/$COMPOSE_PATTERN" "$env_args" "up -d"
      
		fi
    echo
	else
		warning "No $c app found"
	fi
  done
}

function enable(){
  local containers="$@"
  for c in $containers
  do
    if ls $DOCKER_FILES/$c 1>/dev/null 2>&1
    then
      if ! ls $DOCKER_FILES/$c/$ENABLED_MARKER 1>/dev/null 2>&1
      then
        debug "Creating enabled marker: $DOCKER_FILES/$c/$ENABLED_MARKER"
        touch $DOCKER_FILES/$c/$ENABLED_MARKER
        echo "$c app is enabled"
      else
        warning "$c app is already enabled"
      fi
    else
      warning "No $c app found"
    fi
  done
}

function disable(){
  local containers="$@"
  for c in $containers
  do
    if ls $DOCKER_FILES/$c 1>/dev/null 2>&1
    then
      if ls $DOCKER_FILES/$c/$ENABLED_MARKER 1>/dev/null 2>&1
      then
        debug "Removing enabled marker: $DOCKER_FILES/$c/$ENABLED_MARKER"
        rm $DOCKER_FILES/$c/$ENABLED_MARKER
        echo "$c app is now disabled"
      else
        warning "$c app is already disabled"
      fi
    else
      warning "No $c app found"
    fi
  done
}

# Initialize template and .env files if they don't exist
# Returns 0 if files exist or were created successfully, 1 if creation failed
function ensure_templates_exist(){
  local needs_init=0
  
  if [ ! -f "$DOCKER_FILES/docker-compose.yaml.template" ]; then
    warning "docker-compose.yaml template doesn't exist. Generating a default one."
    debug "Generating template from base64 encoded default"
    echo $DEFAULT_DOCKERCOMPOSE_TEMPLATE_B64 | base64 -d >> "$DOCKER_FILES/docker-compose.yaml.template"
    chmod 640 "$DOCKER_FILES/docker-compose.yaml.template"
    echo "You can now edit it with 'stack edit template'"
    needs_init=1
  fi

  if [ ! -f "$DOCKER_FILES/.env" ]; then
    warning ".env doesn't exist. Generating a default one."
    debug "Generating .env from base64 encoded default"
    echo $DEFAULT_ENV_TEMPLATE_B64 | base64 -d >> "$DOCKER_FILES/.env"
    sed -i.bak -e "s|##CONFIG_FOLDER##|$DOCKER_FILES|g" "$DOCKER_FILES/.env" && rm -f "$DOCKER_FILES/.env.bak"
    chmod 640 "$DOCKER_FILES/.env"
    echo "You can now edit it with 'stack edit .env'"
    needs_init=1
  fi
  
  return $needs_init
}

# Validate container name (no special characters that could cause issues)
function validate_container_name(){
  local name="$1"
  
  # Check for empty name
  if [ -z "$name" ]; then
    error "Container name cannot be empty"
    return 1
  fi
  
  # Check for 'all' keyword
  if [ "$name" = "all" ]; then
    error "Container name cannot be 'all' (reserved keyword)"
    return 1
  fi
  
  # Check for invalid characters (allow alphanumeric, dash, underscore, dot)
  if [[ ! "$name" =~ ^[a-zA-Z0-9._-]+$ ]]; then
    error "Invalid container name: '$name'. Only alphanumeric characters, dash, underscore, and dot are allowed."
    return 1
  fi
  
  return 0
}

function create(){
  # Ensure templates exist before creating a new stack
  ensure_templates_exist

  # Validate container name
  if ! validate_container_name "$1"; then
    exit $EXIT_INVALID_INPUT
  fi
  
  debug "Creating new stack: $1"
  if ! ls $DOCKER_FILES/$1 1>/dev/null 2>&1
  then
    debug "Creating directory structure: $DOCKER_FILES/$1/data/config"
    mkdir -p $DOCKER_FILES/$1/data/config
    chmod -R 770 $DOCKER_FILES/$1
    debug "Creating symlink: $DOCKER_FILES/$1/.env -> ../.env"
    ln -s ../.env $DOCKER_FILES/$1/.env
    debug "Copying template and replacing ##CONTAINER## with $1"
    cp $DOCKER_FILES/docker-compose.yaml.template $DOCKER_FILES/$1/docker-compose.yaml
    sed -i.bak -e "s/##CONTAINER##/$1/g" "$DOCKER_FILES/$1/docker-compose.yaml" && rm -f "$DOCKER_FILES/$1/docker-compose.yaml.bak"
    echo File structure for $1 created in $DOCKER_FILES/$1
  else
    warning "$1 app already exists"
  fi

}

function remove(){
  local containers="$@"
  for c in $containers
  do
    if ls $DOCKER_FILES/$c 1>/dev/null 2>&1
    then
      read -p "Delete $c? [Y|N]: " -n 1 -r
      echo    # (optional) move to a new line
      if [[ $REPLY =~ ^[Yy]$ ]]
      then
        debug "Removing directory: $DOCKER_FILES/$c"
        echo "Deleting $c"
        rm -rf $DOCKER_FILES/$c
        if (( $? > 0 )); then
          echo "An error occured while deleting $c. Some files may belong to another user."
          read -p "Let's try as root (sudo)? [Y|N]: " -n 1 -r
          echo    # (optional) move to a new line
          if [[ $REPLY =~ ^[Yy]$ ]]
          then
            debug "Attempting removal with sudo"
            echo "Deleting $c as root"
            sudo rm -rf $DOCKER_FILES/$c
          fi
        fi
        
      fi
      
    else
      warning "No $c app found"
    fi
  done
}

function edit(){
  if [[ "${1}" == "template" ]]; then
    $EDITOR $DOCKER_FILES/docker-compose.yaml.template
  elif [[ "${1}" == ".env" ]]; then
    $EDITOR $DOCKER_FILES/.env
  elif ls $DOCKER_FILES/$1/$COMPOSE_PATTERN 1>/dev/null 2>&1
  then
    $EDITOR $DOCKER_FILES/$1/$COMPOSE_PATTERN
  else
    warning " No $1 app found" 
  fi
  
}


function pause(){
  local containers="$@"
  for c in $containers
  do
    if ls $DOCKER_FILES/$c/$COMPOSE_PATTERN 1>/dev/null 2>&1
    then
      local env_args=$(get_env_files "$DOCKER_FILES/$c")
      if [[ ! -z $(docker_compose_exec "$DOCKER_FILES/$c/$COMPOSE_PATTERN" "$env_args" "top") ]]
      then
        echo "Stop $c and mark for restart"
        docker_compose_exec "$DOCKER_FILES/$c/$COMPOSE_PATTERN" "$env_args" "down"
        debug "Creating pause marker: $DOCKER_FILES/$c/$PAUSED_MARKER"
        touch $DOCKER_FILES/$c/$PAUSED_MARKER
      fi
    else
      warning "No $c app found"
    fi
  done
}

function unpause(){

  local containers="$@"
  for c in $containers
  do
    if ls $DOCKER_FILES/$c/$COMPOSE_PATTERN 1>/dev/null 2>&1
    then
      local env_args=$(get_env_files "$DOCKER_FILES/$c")
      if ls $DOCKER_FILES/$c/$PAUSED_MARKER 1>/dev/null 2>&1
      then
        echo "Restarting paused stack $c ..."
        docker_compose_exec "$DOCKER_FILES/$c/$COMPOSE_PATTERN" "$env_args" "up -d"
        debug "Removing pause marker: $DOCKER_FILES/$c/$PAUSED_MARKER"
        rm $DOCKER_FILES/$c/$PAUSED_MARKER
      fi
    else
      warning "No $c app found"
    fi
  done
}

function init(){
  ensure_templates_exist
  echo "Initialization complete."
}

function set-docker-compose-bin(){
  debug "Detecting container runtime and compose tool..."
  
  if docker compose version >/dev/null 2>&1
  then
    DOCKER_COMPOSE_BIN="docker compose"
    debug "Detected: docker compose (plugin)"
  elif docker-compose --version >/dev/null 2>&1
  then
    DOCKER_COMPOSE_BIN="docker-compose"
    debug "Detected: docker-compose (standalone)"
  elif podman compose version >/dev/null 2>&1
  then
    DOCKER_COMPOSE_BIN="podman compose"
    debug "Detected: podman compose (plugin)"
  elif command -v podman-compose &> /dev/null
  then
    DOCKER_COMPOSE_BIN="podman-compose"
    debug "Detected: podman-compose (standalone)"
  else
    error "No container runtime with compose support found (tried: docker compose, docker-compose, podman compose, podman-compose). Aborting."
    exit $EXIT_NO_COMPOSE_TOOL
  fi
}

function docker-privileges-check(){
  local docker_not_required_for="list enable disable create remove edit init"
  if [[ "$docker_not_required_for" != *"$1"* ]]; then
    debug "Checking privileges for: $DOCKER_COMPOSE_BIN"
    $DOCKER_COMPOSE_BIN version >/dev/null 2>&1
    local RC=$?
    if (( $RC != 0 )); then
      error "Cannot execute '$DOCKER_COMPOSE_BIN'. Check permissions or installation. Aborting."
      debug "You may need to: run with sudo, add user to docker/podman group, or check if the runtime is properly installed."
      exit $EXIT_DOCKER_PERMISSION
    fi
    debug "Privileges check passed"
  fi
}

function self-update(){
  
  # Cross-platform way to resolve script path (works on macOS and Linux)
  SOURCE="${BASH_SOURCE[0]}"
  while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
  done
  SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SCRIPT_NAME="$(basename "$SOURCE")"
  SCRIPT_FULLPATH="$SCRIPT_DIR/$SCRIPT_NAME"
  echo "script dir is $SCRIPT_DIR and name $SCRIPT_NAME"
  if [ ! -w "$SCRIPT_FULLPATH" ]; then
    error "File \"$SCRIPT_FULLPATH\" is NOT writeable"
    error "You may need to run Self-update as root or with sudo! Aborting self-update..."
    exit $EXIT_GENERAL_ERROR
  fi

  # SOURCE=${BASH_SOURCE[0]}
  # while [ -L "$SOURCE" ]; do # resolve $SOURCE until the file is no longer a symlink
  #   DIR=$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )
  #   SOURCE=$(readlink "$SOURCE")
  #   [[ $SOURCE != /* ]] && SOURCE=$DIR/$SOURCE # if $SOURCE was a relative symlink, we need to resolve it relative to the path where the symlink file was located
  # done
  # DIR=$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )


  echo "Updating script to $SCRIPT_FULLPATH"
  curl -s -o $SCRIPT_FULLPATH https://raw.githubusercontent.com/gauth-fr/docker-stack/main/stack
  chmod 755 $SCRIPT_FULLPATH
  sed -i.bak -e "s|##DOCKER_FILES##|$DOCKER_FILES|g" "$SCRIPT_FULLPATH" && rm -f "$SCRIPT_FULLPATH.bak"

  if [ -d "/etc/bash_completion.d" ]; then
    echo "Updating completion file to /etc/bash_completion.d/stack.completion"
    curl -s -o /etc/bash_completion.d/stack.completion https://raw.githubusercontent.com/gauth-fr/docker-stack/main/stack.completion
    chmod 644 /etc/bash_completion.d/stack.completion 
  else
    warning "/etc/bash_completion.d doesn't exist. Completion won't be installed/updated."
    echo "However, you can get the bash completion script here: https://raw.githubusercontent.com/gauth-fr/docker-stack/main/stack.completion"
  fi
}

main "$@";
